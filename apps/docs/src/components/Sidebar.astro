---
import { groupManifestsByCategory, type ComponentManifest } from '@/lib/registry';

interface Props {
  manifests: ComponentManifest[];
  active?: string;
}

const { manifests, active } = Astro.props;
const groups = groupManifestsByCategory(manifests);
---

<nav class="text-sm space-y-6 sticky top-20">
  {groups.map(({ category, manifests: categoryManifests }) => (
    <section>
      <div class="mb-3 flex items-center justify-between gap-3">
        <h3 class="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--diamond-muted)]">
          {category.label}
        </h3>
        <span class="font-mono text-[9px] text-[var(--diamond-muted)]">{categoryManifests.length}</span>
      </div>
      <ul class="space-y-1">
        {categoryManifests.map((m) => (
          <li>
            <a
              href={`/components/${m.id}`}
              class:list={[
                'block px-2 py-1 rounded-md transition-colors',
                active === m.id
                  ? 'bg-[var(--diamond-accent-soft)] text-[var(--diamond-accent-deep)] font-medium'
                  : 'text-[var(--diamond-muted)] hover:bg-[var(--diamond-surface-alt)] hover:text-[var(--diamond-ink)]',
              ]}
            >
              {m.name}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</nav>
