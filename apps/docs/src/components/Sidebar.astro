---
import type { ComponentManifest } from '@/lib/registry';

interface Props {
  manifests: ComponentManifest[];
  active?: string;
}

const { manifests, active } = Astro.props;

/* Group by manifest.kind so the sidebar mirrors the lib's component taxonomy. */
const groups: Record<string, ComponentManifest[]> = {};
const order = ['ui', 'theme', 'hook', 'util', 'primitive'] as const;
for (const m of manifests) {
  (groups[m.kind] ??= []).push(m);
}

const labels: Record<string, string> = {
  ui: 'UI',
  theme: 'Themes',
  hook: 'Hooks',
  util: 'Utilities',
  primitive: 'Primitives',
};
---

<nav class="text-sm space-y-6 sticky top-20">
  {order.filter((k) => groups[k]?.length).map((kind) => (
    <section>
      <h3 class="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--diamond-muted)] mb-3">
        {labels[kind]}
      </h3>
      <ul class="space-y-1">
        {groups[kind]!.map((m) => (
          <li>
            <a
              href={`/components/${m.id}`}
              class:list={[
                'block px-2 py-1 rounded-md transition-colors',
                active === m.id
                  ? 'bg-[var(--diamond-accent-soft)] text-[var(--diamond-accent-deep)] font-medium'
                  : 'text-[var(--diamond-muted)] hover:bg-[var(--diamond-surface-alt)] hover:text-[var(--diamond-ink)]',
              ]}
            >
              {m.name}
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</nav>
