{
  "id": "progress",
  "name": "Progress",
  "description": "Linear progress with %, stepped, striped, indeterminate and terminal ASCII styles.",
  "kind": "ui",
  "files": [
    { "source": "progress.tsx", "target": "progress.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["feedback", "progress"],

  "documentation": {
