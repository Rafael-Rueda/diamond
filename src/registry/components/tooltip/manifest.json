{
  "id": "tooltip",
  "name": "Tooltip",
  "description": "Hover info bubble built on @radix-ui/react-tooltip — label, keyboard shortcut, rich pro-tip, accent, light-bordered and status indicator.",
  "kind": "ui",
  "files": [
    { "source": "tooltip.tsx", "target": "tooltip.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@radix-ui/react-tooltip",  "version": "^1.1.4", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["feedback", "overlay"],

  "documentation": {
    "groups": {
      "Styles": ["label", "shortcut", "rich", "accent", "light", "status"]
    },
    "samples": {
      "default": "Hover me",
      "perVariant": {
        "label":    { "label": "Hover me" },
        "shortcut": { "label": "⌘" },
        "rich":     { "label": "Help" },
        "accent":   { "label": "★" },
        "light":    { "label": "?" },
        "status":   { "label": "Status" }
      }
    }
  }
}
