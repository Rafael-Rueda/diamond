{
  "id": "notification-center",
  "name": "Notification Center",
  "description": "Grouped notifications panel with read/unread state, optional tabs and time grouping — classic, tabbed, grouped, dark, calendar and banner layouts.",
  "kind": "ui",
  "files": [
    { "source": "notification-center.tsx", "target": "notification-center.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["feedback", "notifications"],

  "documentation": {
    "groups": {
      "Layouts": ["classic", "tabbed", "grouped", "dark", "calendar", "banner"]
    },
    "samples": {
      "default": "Notifications",
      "perVariant": {
        "classic":  { "label": "Notifications" },
        "tabbed":   { "label": "Inbox" },
        "grouped":  { "label": "Today" },
        "dark":     { "label": "Activity" },
        "calendar": { "label": "" },
        "banner":   { "label": "" }
      }
    }
  }
}
