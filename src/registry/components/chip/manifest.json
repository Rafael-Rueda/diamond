{
  "id": "chip",
  "name": "Chip",
  "description": "Interactive labels — filterable, dismissible, with dot/emoji/add variants.",
  "kind": "ui",
  "files": [
    { "source": "chip.tsx", "target": "chip.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@radix-ui/react-slot",     "version": "^1.1.0", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["display", "interactive"],

  "documentation": {
    "groups": {
      "Display": ["basic", "dismissible", "filter", "dot", "emoji", "add"]
    },
    "samples": {
      "default": "Design",
      "perVariant": {
        "filter": { "label": "Active", "props": { "active": true } },
        "emoji":  { "label": "Design" },
        "add":    { "label": "Add tag" }
      }
    }
  }
}
