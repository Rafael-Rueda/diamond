{
  "id": "badge",
  "name": "Badge",
  "description": "Count, status, dot, and label variations with semantic tones and floating support.",
  "kind": "ui",
  "files": [
    { "source": "badge.tsx", "target": "badge.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@radix-ui/react-slot",     "version": "^1.1.0", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["display"],

  "documentation": {
    "groups": {
      "Display": ["count", "status", "overflow", "dot", "icon", "label"]
    },
    "samples": {
      "default": "8",
      "perVariant": {
        "status":   { "label": "NEW" },
        "overflow": { "label": "99+" },
        "dot":      { "label": "" },
        "icon":     { "label": "3" },
        "label":    { "label": "v3.2" }
      }
    }
  }
}
