{
  "id": "command-palette",
  "name": "Command Palette",
  "description": "Searchable command launcher with project, suggested, terminal, jump, people and AI prompt variants.",
  "kind": "ui",
  "files": [
    { "source": "command-palette.tsx", "target": "command-palette.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx", "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge", "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["command", "search", "navigation"],
  "documentation": {
    "groups": {
      "Launcher": ["project", "suggested", "terminal", "jump", "people", "ask"]
    },
    "samples": {
      "default": "Search",
      "perVariant": {
        "project": { "label": "Project switcher" },
        "suggested": { "label": "Suggested actions" },
        "terminal": { "label": "Terminal commands" },
        "jump": { "label": "Jump to" },
        "people": { "label": "People search" },
        "ask": { "label": "Ask Diamond" }
      }
    }
  }
}
