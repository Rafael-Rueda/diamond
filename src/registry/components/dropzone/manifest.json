{
  "id": "dropzone",
  "name": "Dropzone",
  "description": "Drag-and-drop file area — classic big, compact row, grid slots, with progress, hatched pattern, circular avatar.",
  "kind": "ui",
  "files": [
    { "source": "dropzone.tsx", "target": "dropzone.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "upload"],

  "documentation": {
    "groups": {
      "Dropzone": ["classic", "compact-row", "grid-slots", "with-progress", "hatched", "circular"]
    },
    "samples": {
      "default": "Drop files here",
      "perVariant": {
        "classic":       { "label": "Drop files here" },
        "compact-row":   { "label": "Drop files" },
        "grid-slots":    { "label": "" },
        "with-progress": { "label": "Uploading…" },
        "hatched":       { "label": "Drop assets" },
        "circular":      { "label": "Avatar" }
      }
    }
  }
}
