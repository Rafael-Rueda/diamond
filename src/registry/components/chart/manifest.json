{
  "id": "chart",
  "name": "Chart",
  "description": "Small SVG chart primitives for area lines, bars, donuts, scatter plots, target bars and radar charts.",
  "kind": "ui",
  "files": [
    { "source": "chart.tsx", "target": "chart.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx", "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge", "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["chart", "data", "visualization"],
  "documentation": {
    "groups": {
      "Charts": ["area-line", "bars", "donut", "scatter", "target-bars", "radar"]
    },
    "samples": {
      "default": "Chart",
      "perVariant": {
        "area-line": { "label": "Area line" },
        "bars": { "label": "Bars" },
        "donut": { "label": "Donut" },
        "scatter": { "label": "Scatter" },
        "target-bars": { "label": "Target bars" },
        "radar": { "label": "Radar" }
      }
    }
  }
}
