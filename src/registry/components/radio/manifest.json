      "perVariant": {
        "dot":            { "label": "Monthly" },
        "square":         { "label": "Square pick" },
        "bullseye":       { "label": "Bullseye" },
        "card":           { "label": "Starter" },
        "segmented":      { "label": "Grid" },
        "size-pill":      { "label": "Medium" },
        "vertical":       { "label": "" },
        "plan-cards":     { "label": "" },
        "segmented-bar":  { "label": "" },
        "icon-grid":      { "label": "" },
        "scale":          { "label": "" },
        "stacked-list":   { "label": "" }
      }
    }
  }
}
