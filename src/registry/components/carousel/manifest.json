{
  "id": "carousel",
  "name": "Carousel",
  "description": "Transform-based slider with drag / swipe (touch + mouse), keyboard navigation, pause-on-hover autoplay, configurable slidesPerView and loop, across dots / arrows / thumbs / cards / circular / progress variants.",
  "kind": "ui",
  "files": [
    { "source": "carousel.tsx", "target": "carousel.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["display", "media"],

  "documentation": {
    "groups": {
      "Display": ["dots", "arrows", "thumbs", "cards", "circular", "progress"]
    },
    "samples": {
      "default": "",
      "perVariant": {}
    }
  }
}
