{
  "id": "color-picker",
  "name": "Color Picker",
  "description": "Color selection — swatch grid, hex input, color wheel, HSL sliders, hue strip, shade scale.",
  "kind": "ui",
  "files": [
    { "source": "color-picker.tsx", "target": "color-picker.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "input"],

  "documentation": {
    "groups": {
      "Color": ["swatches", "hex", "wheel", "hsl", "strip", "shades"]
    },
    "samples": {
      "default": "Color",
      "perVariant": {
        "swatches": { "label": "" },
        "hex":      { "label": "" },
        "wheel":    { "label": "" },
        "hsl":      { "label": "" },
        "strip":    { "label": "" },
        "shades":   { "label": "" }
      }
    }
  }
