{
  "id": "offline-indicator",
  "name": "Offline Indicator",
  "description": "Network loss banners — subscribes to navigator.onLine and renders a top-bar, pill, chip, reconnecting spinner, blocker overlay or retry toast.",
  "kind": "ui",
  "files": [
    { "source": "offline-indicator.tsx", "target": "offline-indicator.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "@radix-ui/react-slot",     "version": "^1.1.0", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["feedback", "network"],

  "documentation": {
    "groups": {
      "Network": ["top-bar", "pill", "chip", "reconnecting", "blocker", "retry"]
    },
    "samples": {
      "default": "Offline",
      "perVariant": {
        "top-bar":      { "label": "" },
        "pill":         { "label": "" },
        "chip":         { "label": "" },
        "reconnecting": { "label": "" },
        "blocker":      { "label": "" },
        "retry":        { "label": "" }
      }
    }
  }
}
