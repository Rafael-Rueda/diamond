{
  "id": "tour",
  "name": "Tour",
  "description": "Multi-step product tour — `<Tour>` orchestrator with spotlight cutout, automatic positioning, keyboard nav and 5 card variants. Plus `<TourCard>` for standalone callouts and `<TourSpotlight>` for a pulsing ring. Target any element via selector, ref or callback.",
  "kind": "ui",
  "files": [
    { "source": "tour.tsx", "target": "tour.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["overlay", "onboarding"],

  "documentation": {
    "groups": {
      "Tour": ["step", "import", "dark-tip", "accent-final", "new-feature", "spotlight"]
    },
    "samples": {
      "default": "Tour step",
      "perVariant": {
        "step":         { "label": "Create your first project" },
        "import":       { "label": "Import existing data" },
        "dark-tip":     { "label": "Quick tip" },
        "accent-final": { "label": "You're all set!" },
        "new-feature":  { "label": "Realtime collaboration" },
        "spotlight":    { "label": "Launch real tour" }
      }
    }
  }
}
