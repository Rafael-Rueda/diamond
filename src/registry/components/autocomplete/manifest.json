{
  "id": "autocomplete",
  "name": "Autocomplete",
  "description": "Typeahead input with filtered suggestions — basic, with hints, with recents, @ mentions, slash commands and inline ghost hint.",
  "kind": "ui",
  "files": [
    { "source": "autocomplete.tsx", "target": "autocomplete.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "input"],

  "documentation": {
    "groups": {
      "Autocomplete": ["basic", "hints", "recents", "mentions", "slash", "ghost"]
    },
    "samples": {
      "default": "Type to search…",
      "perVariant": {
        "basic":    { "label": "" },
        "hints":    { "label": "" },
        "recents":  { "label": "" },
        "mentions": { "label": "Mention with @" },
        "slash":    { "label": "Run /command" },
        "ghost":    { "label": "" }
      }
    }
  }
}
