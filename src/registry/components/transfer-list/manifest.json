{
  "id": "transfer-list",
  "name": "Transfer List",
  "description": "Dual-list mover for assignments, approvals, avatar pools, filters and permission scopes.",
  "kind": "ui",
  "files": [
    { "source": "transfer-list.tsx", "target": "transfer-list.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx", "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge", "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "selection", "permissions"],
  "documentation": {
    "groups": {
      "Transfer": ["classic", "drag", "approval", "avatars", "filter", "scopes-dark"]
    },
    "samples": {
      "default": "Transfer",
      "perVariant": {
        "classic": { "label": "Classic paired" },
        "drag": { "label": "Drag into plan" },
        "approval": { "label": "Approve or reject" },
        "avatars": { "label": "Avatar pool" },
        "filter": { "label": "With filter" },
        "scopes-dark": { "label": "Permission scopes" }
      }
    }
  }
}
