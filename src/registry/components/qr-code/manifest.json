{
  "id": "qr-code",
  "name": "QR Code",
  "description": "QR matrix renderer with branded, inverted, Wi-Fi, export and error-level variants.",
  "kind": "ui",
  "files": [
    { "source": "qr-code.tsx", "target": "qr-code.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx", "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge", "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["qr", "code", "utility"],
  "documentation": {
    "groups": {
      "QR Code": ["classic", "branded", "inverted", "wifi", "export", "error-level"]
    },
    "samples": {
      "default": "QR",
      "perVariant": {
        "classic": { "label": "Classic mono" },
        "branded": { "label": "Branded center" },
        "inverted": { "label": "Inverted dark" },
        "wifi": { "label": "Wi-Fi credential" },
        "export": { "label": "Export actions" },
        "error-level": { "label": "Error level" }
      }
    }
  }
}
