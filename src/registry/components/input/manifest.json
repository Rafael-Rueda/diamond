{
  "id": "input",
  "name": "Input",
  "description": "Consolidated single-line input — text, password, number, search and masked types in one component. Wraps the real <input>; visual variants live in `variant`.",
  "kind": "ui",
  "files": [
    { "source": "input.tsx", "target": "input.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "input"],

  "documentation": {
    "groups": {
      "Text":     ["classic", "underline", "filled", "floating", "terminal", "search-pill"],
      "Password": ["reveal", "strength", "underline-reveal", "digits", "terminal-password", "criteria"],
      "Number":   ["stepper", "vertical-stepper", "slider", "currency", "pick-one-to-nine", "terminal-number"],
      "Search":   ["search-cmd", "search-soft", "search-floaty", "search-grep", "search-scoped"],
      "Mask":     ["mask"]
    },
    "samples": {
      "default": "Jane Doe",
      "perVariant": {
        "classic":           { "label": "Jane Doe" },
        "underline":         { "label": "Email address" },
        "filled":            { "label": "Your name" },
        "floating":          { "label": "Full name" },
        "terminal":          { "label": "~/projects $" },
        "search-pill":       { "label": "Search…" },
        "reveal":            { "label": "Password" },
        "strength":          { "label": "Password" },
        "underline-reveal":  { "label": "Password" },
        "digits":            { "label": "" },
        "terminal-password": { "label": "" },
        "criteria":          { "label": "Password" },
        "stepper":           { "label": "" },
        "vertical-stepper":  { "label": "" },
        "slider":            { "label": "" },
        "currency":          { "label": "0.00" },
        "pick-one-to-nine":  { "label": "" },
        "terminal-number":   { "label": "42" },
        "search-cmd":        { "label": "Search…" },
        "search-soft":       { "label": "Search…" },
        "search-floaty":     { "label": "Search…" },
        "search-grep":       { "label": "" },
        "search-scoped":     { "label": "Search docs…" },
        "mask":              { "label": "(555) 123-4567" }
      }
    }
  }
}
