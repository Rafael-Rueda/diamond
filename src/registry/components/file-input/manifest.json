{
  "id": "file-input",
  "name": "File Input",
  "description": "Single file picker wrapping <input type=\"file\"> — classic upload, segmented filename + browse, image preview tile, dashed attach, terminal, FAB +.",
  "kind": "ui",
  "files": [
    { "source": "file-input.tsx", "target": "file-input.tsx", "alias": "ui" }
  ],
  "dependencies": [
    { "name": "@phosphor-icons/react",    "version": "^2.1.7", "kind": "runtime" },
    { "name": "class-variance-authority", "version": "^0.7.0", "kind": "runtime" },
    { "name": "clsx",                     "version": "^2.1.1", "kind": "runtime" },
    { "name": "tailwind-merge",           "version": "^2.5.4", "kind": "runtime" }
  ],
  "registryDependencies": ["utils"],
  "tags": ["forms", "upload"],

  "documentation": {
    "groups": {
      "File": ["classic", "segmented", "image-preview", "attach", "terminal", "fab"]
    },
    "samples": {
      "default": "Upload file",
      "perVariant": {
        "classic":       { "label": "Upload file" },
        "segmented":     { "label": "Choose a file" },
        "image-preview": { "label": "PHOTO" },
        "attach":        { "label": "Attach a file" },
        "terminal":      { "label": "" },
        "fab":           { "label": "Add file" }
      }
    }
  }
}
